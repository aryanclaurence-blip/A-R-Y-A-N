<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:s="clr-namespace:System;assembly=mscorlib"
        Title="ColorSplasher Pro"
        Height="740" Width="1120" MinWidth="1080" MinHeight="680"
        ShowInTaskbar="True" ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="#F6F8FB"
        FontFamily="Segoe UI"
        FontSize="12"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="TextDark" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#2563EB"/>
        <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/>

        <!-- Bento Card Style -->
        <Style x:Key="BentoCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#0F172A" BlurRadius="10" Direction="270" ShadowDepth="3" Opacity="0.10"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bento Card Style with Hover -->
        <Style x:Key="BentoCardHover" TargetType="Border" BasedOn="{StaticResource BentoCard}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#0F172A" BlurRadius="18" Direction="270" ShadowDepth="6" Opacity="0.15"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Section Label Style -->
        <Style x:Key="BentoLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Standard Dropdowns & Textbox -->
        <Style x:Key="CleanCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style x:Key="CleanTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <!-- Toggle Cards Style for RadioButtons -->
        <Style x:Key="ModeRadioButton" TargetType="RadioButton">
            <Setter Property="GroupName" Value="ColorMode"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="White" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="6,12">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="icon" FontFamily="Segoe MDL2 Assets" FontSize="26" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock x:Name="title" Text="{TemplateBinding Content}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextDark}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                <TextBlock x:Name="desc" FontSize="9" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Content" Value="Standard">
                                <Setter TargetName="icon" Property="Text" Value="&#xE790;"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#2563EB"/>
                                <Setter TargetName="desc" Property="Text" Value="Color by values"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Heat Map">
                                <Setter TargetName="icon" Property="Text" Value="&#xE9E9;"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#F59E0B"/>
                                <Setter TargetName="desc" Property="Text" Value="Color by ranges"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Multi-Param">
                                <Setter TargetName="icon" Property="Text" Value="&#xF158;"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#7C3AED"/>
                                <Setter TargetName="desc" Property="Text" Value="Combine parameters"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="border" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="title" Property="Foreground" Value="#2563EB"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="BorderBrush" Value="#94A3B8"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SourceRadioButton" TargetType="RadioButton">
            <Setter Property="GroupName" Value="LinkMode"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="White" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="6,12">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="icon" FontFamily="Segoe MDL2 Assets" FontSize="26" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock x:Name="title" Text="{TemplateBinding Content}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextDark}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Content" Value="Host">
                                <Setter TargetName="icon" Property="Text" Value="&#xE80F;"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#64748B"/>
                                <Setter TargetName="title" Property="Text" Value="Host Model"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Links">
                                <Setter TargetName="icon" Property="Text" Value="&#xE71B;"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#64748B"/>
                                <Setter TargetName="title" Property="Text" Value="Linked Models"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Host + Links">
                                <Setter TargetName="icon" Property="Text" Value="&#xE9A1;"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#2563EB"/>
                                <Setter TargetName="title" Property="Text" Value="Host + Links"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="border" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="title" Property="Foreground" Value="#2563EB"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#2563EB"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="BorderBrush" Value="#94A3B8"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScopeRadioButton" TargetType="RadioButton">
            <Setter Property="GroupName" Value="SelectionScope"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="#F8FAFC" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="6" Padding="12,6" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="icon" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="title" Text="{TemplateBinding Content}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextDark}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Content" Value="Whole Model">
                                <Setter TargetName="icon" Property="Text" Value="&#xE774;"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#64748B"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Current View">
                                <Setter TargetName="icon" Property="Text" Value="&#xE7B3;"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#64748B"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Selected Elements">
                                <Setter TargetName="icon" Property="Text" Value="&#xE8B0;"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#64748B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="border" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="title" Property="Foreground" Value="#2563EB"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Checkbox Tile Border Style -->
        <Style x:Key="CheckTile" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Setter Property="BorderBrush" Value="#CBD5E1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Standard Button Styles -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnActionTile" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="76"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="icon" FontFamily="Segoe MDL2 Assets" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock Text="{TemplateBinding Content}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDark}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="random">
                                <Setter TargetName="icon" Property="Text" Value="&#xE91B;"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#10B981"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="gradient">
                                <Setter TargetName="icon" Property="Text" Value="&#xE706;"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="heatmap">
                                <Setter TargetName="icon" Property="Text" Value="&#xE9E9;"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#F59E0B"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="random"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#ECFDF5"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#10B981"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#10B981" BlurRadius="8" Direction="270" ShadowDepth="2" Opacity="0.15"/>
                                    </Setter.Value>
                                </Setter>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="gradient"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#F5F3FF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#7C3AED"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#7C3AED" BlurRadius="8" Direction="270" ShadowDepth="2" Opacity="0.15"/>
                                    </Setter.Value>
                                </Setter>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="heatmap"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#FFFBEB"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#F59E0B"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#F59E0B" BlurRadius="8" Direction="270" ShadowDepth="2" Opacity="0.15"/>
                                    </Setter.Value>
                                </Setter>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#2563EB" Offset="0"/>
            <GradientStop Color="#1D4ED8" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#2563EB" BlurRadius="12" Direction="270" ShadowDepth="3" Opacity="0.30"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#1D4ED8" Offset="0"/>
                                            <GradientStop Color="#1E40AF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#1D4ED8" BlurRadius="18" Direction="270" ShadowDepth="4" Opacity="0.40"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="BorderBrush" Value="#94A3B8"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#0F172A" BlurRadius="6" Direction="270" ShadowDepth="2" Opacity="0.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Foreground" Value="{StaticResource DangerRed}"/>
            <Setter Property="BorderBrush" Value="#FCA5A5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="White" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FEF2F2"/>
                                <Setter Property="BorderBrush" Value="{StaticResource DangerRed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Clean CheckBox -->
        <Style x:Key="CleanCheck" TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Custom GridView Column Header Style -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Data Table ListView Style -->
        <Style x:Key="BentoListView" TargetType="ListView">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Height" Value="34"/>
                        <Setter Property="BorderBrush" Value="#F1F5F9"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="rowBorder" Background="Transparent" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <GridViewRowPresenter Content="{TemplateBinding Content}" Columns="{TemplateBinding GridView.ColumnCollection}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="rowBorder" Property="Background" Value="#F1F5F9"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="rowBorder" Property="Background" Value="#DBEAFE"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Selection Scope Bar -->
            <RowDefinition Height="Auto"/> <!-- Top row -->
            <RowDefinition Height="Auto"/> <!-- Second row -->
            <RowDefinition Height="*"/>    <!-- Third row (main table + right columns) -->
            <RowDefinition Height="Auto"/> <!-- Bottom toolbar -->
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════ SELECTION SCOPE ROW ════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource BentoCard}" Margin="0,0,0,12" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE8B0;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#64748B" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="SELECTION SCOPE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <RadioButton x:Name="_radio_scope_whole" Style="{StaticResource ScopeRadioButton}" Content="Whole Model" Checked="on_scope_changed"/>
                    <RadioButton x:Name="_radio_scope_view" Style="{StaticResource ScopeRadioButton}" Content="Current View" IsChecked="True" Checked="on_scope_changed"/>
                    <RadioButton x:Name="_radio_scope_selected" Style="{StaticResource ScopeRadioButton}" Content="Selected Elements" Checked="on_scope_changed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════ TOP ROW ════════════════════════ -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- 1. Category -->
            <Border Grid.Column="0" Style="{StaticResource BentoCard}" Margin="0,0,16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Icon block -->
                    <Border Grid.Column="0" Width="42" Height="42" Background="#EFF6FF" CornerRadius="8" Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="1. CATEGORY" Style="{StaticResource BentoLabel}" Margin="0,0,0,2"/>
                        <ComboBox x:Name="_categories" Style="{StaticResource CleanCombo}" DisplayMemberPath="Key"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. Parameter -->
            <Border Grid.Column="1" Style="{StaticResource BentoCard}" Margin="0,0,16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="42" Height="42" Background="#F5F3FF" CornerRadius="8" Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="#7C3AED" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="2. PARAMETER" Style="{StaticResource BentoLabel}" Margin="0,0,0,2"/>
                        <ComboBox x:Name="_list_box1" Style="{StaticResource CleanCombo}" DisplayMemberPath="Key" SelectionChanged="check_item"/>
                        
                        <!-- Dynamic Parameters Panel (visible only in Multi-Param mode) -->
                        <StackPanel Visibility="{Binding IsChecked, ElementName=_radio_multi, Converter={StaticResource BoolToVis}}" Margin="0,6,0,0">
                            <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto" Margin="0,0,0,4">
                                <StackPanel x:Name="_panel_multi_params"/>
                            </ScrollViewer>
                            <Button x:Name="_btn_add_param" Style="{StaticResource BtnSecondary}" Height="30" Content="+ Add Parameter" Click="btn_add_param_click" ToolTip="Add another parameter dropdown for compound key coloring"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 3. Search Values -->
            <Border Grid.Column="2" Style="{StaticResource BentoCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="42" Height="42" Background="#ECFDF5" CornerRadius="8" Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="&#xE1C3;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="3. SEARCH VALUES" Style="{StaticResource BentoLabel}" Margin="0,0,0,2"/>
                        <Grid>
                            <TextBox x:Name="_search_values" Style="{StaticResource CleanTextBox}" TextChanged="on_search_values_changed" GotFocus="search_values_enter" LostFocus="search_values_leave"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ════════════════════════ SECOND ROW ════════════════════════ -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.8*"/>
                <ColumnDefinition Width="3.8*"/>
                <ColumnDefinition Width="3.4*"/>
            </Grid.ColumnDefinitions>

            <!-- 4. Color Mode -->
            <Border Grid.Column="0" Style="{StaticResource BentoCard}" Margin="0,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="4. COLOR MODE" Style="{StaticResource BentoLabel}"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="_radio_standard" Grid.Column="0" Style="{StaticResource ModeRadioButton}" Content="Standard" IsChecked="True" Checked="on_mode_changed"/>
                        <RadioButton x:Name="_radio_heatmap" Grid.Column="2" Style="{StaticResource ModeRadioButton}" Content="Heat Map" Checked="on_mode_changed"/>
                        <RadioButton x:Name="_radio_multi" Grid.Column="4" Style="{StaticResource ModeRadioButton}" Content="Multi-Param" Checked="on_mode_changed"/>
                    </Grid>
                    
                    <!-- Heat map bands panel -->
                    <StackPanel x:Name="_panel_heatmap_opts" Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                        <TextBlock Text="Bands:" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,8,0"/>
                        <ComboBox x:Name="_combo_bands" Style="{StaticResource CleanCombo}" Width="80" Height="28" SelectedIndex="1">
                            <ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="5"/>
                            <ComboBoxItem Content="7"/>
                            <ComboBoxItem Content="10"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 5. Link & Source -->
            <Border Grid.Column="1" Style="{StaticResource BentoCard}" Margin="0,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="5. LINK &amp; SOURCE" Style="{StaticResource BentoLabel}"/>
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton x:Name="_radio_host" Grid.Column="0" Style="{StaticResource SourceRadioButton}" Content="Host" IsChecked="True" Checked="on_source_changed"/>
                            <RadioButton x:Name="_radio_links" Grid.Column="2" Style="{StaticResource SourceRadioButton}" Content="Links" Checked="on_source_changed"/>
                            <RadioButton x:Name="_radio_all" Grid.Column="4" Style="{StaticResource SourceRadioButton}" Content="Host + Links" Checked="on_source_changed"/>
                        </Grid>
                        <!-- Link Dropdown row -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="_combo_links" Grid.Column="0" Style="{StaticResource CleanCombo}" ToolTip="Select specific link"/>
                            <Button Grid.Column="2" Style="{StaticResource BtnBase}" Width="34" Padding="0" ToolTip="View Revit Link Instances info">
                                <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Grid.Column="4" Style="{StaticResource BtnBase}" Width="34" Padding="0" ToolTip="Refresh Revit links from document">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- 6. Apply Settings -->
            <Border Grid.Column="2" Style="{StaticResource BentoCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="6. APPLY SETTINGS" Style="{StaticResource BentoLabel}"/>
                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <!-- Tile 1 -->
                        <Border Style="{StaticResource CheckTile}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="_chk_foreground_pattern" Grid.Column="0" Style="{StaticResource CleanCheck}" IsChecked="True" Checked="checkbox_changed" Unchecked="checkbox_changed"/>
                                <Border Grid.Column="1" Width="28" Height="28" BorderBrush="#2563EB" BorderThickness="1" CornerRadius="4" Margin="4,0,0,0" Background="#EFF6FF">
                                    <Canvas ClipToBounds="True">
                                        <Line X1="0" Y1="0" X2="28" Y2="28" Stroke="#93C5FD" StrokeThickness="1.5"/>
                                        <Line X1="0" Y1="10" X2="18" Y2="28" Stroke="#93C5FD" StrokeThickness="1.5"/>
                                        <Line X1="10" Y1="0" X2="28" Y2="18" Stroke="#93C5FD" StrokeThickness="1.5"/>
                                        <Line X1="0" Y1="20" X2="8" Y2="28" Stroke="#93C5FD" StrokeThickness="1.5"/>
                                        <Line X1="20" Y1="0" X2="28" Y2="8" Stroke="#93C5FD" StrokeThickness="1.5"/>
                                    </Canvas>
                                </Border>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="Foreground Pattern Color" FontWeight="SemiBold" FontSize="10" Foreground="{StaticResource TextDark}"/>
                                    <TextBlock Text="Fill patterns, cut patterns" FontSize="8" Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- Tile 2 -->
                        <Border Style="{StaticResource CheckTile}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="_chk_background_pattern" Grid.Column="0" Style="{StaticResource CleanCheck}" Checked="checkbox_changed" Unchecked="checkbox_changed"/>
                                <Border Grid.Column="1" Width="28" Height="28" BorderBrush="#64748B" BorderThickness="1" CornerRadius="4" Margin="4,0,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F8FAFC" Offset="0"/>
                                            <GradientStop Color="#CBD5E1" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="Background Pattern Color" FontWeight="SemiBold" FontSize="10" Foreground="{StaticResource TextDark}"/>
                                    <TextBlock Text="Background fills" FontSize="8" Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- Tile 3 -->
                        <Border Style="{StaticResource CheckTile}" Margin="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="_chk_line_color" Grid.Column="0" Style="{StaticResource CleanCheck}" Checked="checkbox_changed" Unchecked="checkbox_changed"/>
                                <Grid Grid.Column="1" Width="28" Height="28" Margin="4,0,0,0">
                                    <Line X1="2" Y1="14" X2="26" Y2="14" Stroke="#475569" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="2" Y1="14" X2="26" Y2="14" Stroke="#EF4444" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Grid>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="Line Color" FontWeight="SemiBold" FontSize="10" Foreground="{StaticResource TextDark}"/>
                                    <TextBlock Text="Element lines and edges" FontSize="8" Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ════════════════════════ THIRD ROW ════════════════════════ -->
        <Grid Grid.Row="3" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5.8*"/>
                <ColumnDefinition Width="4.2*"/>
            </Grid.ColumnDefinitions>

            <!-- 7. Values Card -->
            <Border Grid.Column="0" Style="{StaticResource BentoCard}" Margin="0,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Values header bar -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="7. VALUES" Style="{StaticResource BentoLabel}" VerticalAlignment="Center" Margin="0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Sort by:" Style="{StaticResource BentoLabel}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <ComboBox x:Name="_combo_sort" Style="{StaticResource CleanCombo}" Width="120" Height="28" SelectionChanged="on_sort_changed">
                                <ComboBoxItem Content="A → Z" Tag="az" IsSelected="True"/>
                                <ComboBoxItem Content="Z → A" Tag="za"/>
                                <ComboBoxItem Content="Count ↑" Tag="count_asc"/>
                                <ComboBoxItem Content="Count ↓" Tag="count_desc"/>
                            </ComboBox>
                        </StackPanel>
                        <Button Grid.Column="3" Style="{StaticResource BtnBase}" Width="28" Height="28" Padding="0" ToolTip="Toggle columns list view">
                            <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="12" HorizontalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <!-- Table List -->
                    <Grid Grid.Row="1">
                        <ListView x:Name="list_box2" Style="{StaticResource BentoListView}" AlternationCount="2000">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="#" Width="35">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ListViewItem}}" Foreground="{StaticResource TextMuted}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="VALUE" Width="190">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <!-- Color Swatch next to text -->
                                                    <Border Width="12" Height="12" CornerRadius="3" Margin="0,0,8,0" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" VerticalAlignment="Center"
                                                            Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ListViewItem}}"/>
                                                    <TextBlock Text="{Binding ValText}" FontWeight="SemiBold" Foreground="{StaticResource TextDark}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="COUNT" Width="60">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Count}" Foreground="{StaticResource TextDark}" FontWeight="Bold" TextAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="COLOR" Width="65">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <!-- Color bar -->
                                                <Border Width="45" Height="12" CornerRadius="3" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" VerticalAlignment="Center"
                                                        Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ListViewItem}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="RGB" Width="85">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0}, {1}, {2}">
                                                            <Binding Path="R"/>
                                                            <Binding Path="G"/>
                                                            <Binding Path="B"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="HEX" Width="70">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Hex}" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="SOURCE" Width="95">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Source}" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                        <TextBlock x:Name="_txt_placeholder_values"
                                   Text="Select category and parameter to load values"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="11" Foreground="{StaticResource TextMuted}"
                                   TextAlignment="Center" TextWrapping="Wrap" MaxWidth="250"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Values Footer Info -->
                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="Total Values: " Foreground="{StaticResource TextMuted}" FontSize="10"/>
                            <TextBlock x:Name="_txt_total_values" Text="0" Foreground="{StaticResource TextDark}" FontWeight="Bold" FontSize="10" Margin="0,0,12,0"/>
                            <TextBlock Text="Total Elements: " Foreground="{StaticResource TextMuted}" FontSize="10"/>
                            <TextBlock x:Name="_txt_total_elements" Text="0" Foreground="{StaticResource TextDark}" FontWeight="Bold" FontSize="10"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="(Click color to edit)" FontStyle="Italic" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Right Bento Stack -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 8. Color Generator -->
                <Border Grid.Row="0" Style="{StaticResource BentoCard}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="8. COLOR GENERATOR" Style="{StaticResource BentoLabel}"/>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="_button_random_colors" Grid.Column="0" Style="{StaticResource BtnActionTile}" Tag="random" Content="Random Colors" Click="button_click_random_colors" ToolTip="Generate random colors for all values"/>
                            <Button x:Name="_button_gradient_colors" Grid.Column="2" Style="{StaticResource BtnActionTile}" Tag="gradient" Content="Gradient" Click="button_click_gradient_colors" ToolTip="Generate a color gradient between start and end colors"/>
                            <Button x:Name="_button_heatmap_gen" Grid.Column="4" Style="{StaticResource BtnActionTile}" Tag="heatmap" Content="Heat Map" Click="on_mode_changed" ToolTip="Apply a heat map color range for numeric values"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 9. Preview & 10. Actions Grid -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4.5*"/>
                        <ColumnDefinition Width="5.5*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 9. Preview -->
                    <Border Grid.Column="0" Style="{StaticResource BentoCard}" Margin="0,0,16,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="9. PREVIEW" Style="{StaticResource BentoLabel}"/>
                            <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Viewbox Grid.Row="0" Width="64" Height="64">
                                    <Canvas Width="50" Height="70">
                                        <!-- Top face (light source) -->
                                        <Polygon x:Name="_cube_top" Points="25,5 50,20 25,35 0,20" Fill="#F8FAFC"/>
                                        <!-- Left face (shaded) -->
                                        <Polygon x:Name="_cube_left" Points="0,20 25,35 25,65 0,50" Fill="#E2E8F0"/>
                                        <!-- Right face (darker) -->
                                        <Polygon x:Name="_cube_right" Points="25,35 50,20 50,50 25,65" Fill="#94A3B8"/>
                                        <!-- Stylized BIM wall/grid detail lines overlays -->
                                        <Line X1="0" Y1="30" X2="25" Y2="45" Stroke="#FFFFFF" StrokeThickness="1" Opacity="0.4" IsHitTestVisible="False"/>
                                        <Line X1="0" Y1="42" X2="25" Y2="57" Stroke="#FFFFFF" StrokeThickness="1" Opacity="0.4" IsHitTestVisible="False"/>
                                        <Line X1="25" Y1="45" X2="50" Y2="30" Stroke="#FFFFFF" StrokeThickness="1" Opacity="0.25" IsHitTestVisible="False"/>
                                        <Line X1="25" Y1="57" X2="50" Y2="42" Stroke="#FFFFFF" StrokeThickness="1" Opacity="0.25" IsHitTestVisible="False"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Row="2" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- 10. Actions -->
                    <Border Grid.Column="1" Style="{StaticResource BentoCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="10. ACTIONS" Style="{StaticResource BentoLabel}"/>
                            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                <Button x:Name="_button_create_legend" Style="{StaticResource BtnSecondary}" Margin="0,0,0,10" Click="button_click_create_legend" ToolTip="Generate a legend of colors in a dedicated Revit view">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE80A;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Create Legend" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="_button_create_view_filters" Style="{StaticResource BtnSecondary}" Click="button_click_create_view_filters" ToolTip="Create Revit View Filters mapping categories and parameters to colors">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Create View Filters" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ════════════════════════ BOTTOM TOOLBAR ════════════════════════ -->
        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Reset -->
            <Button x:Name="_button_reset_colors" Grid.Column="0" Style="{StaticResource BtnDanger}" Click="button_click_reset" Width="140" ToolTip="Remove color overrides from all elements in the active view">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Reset Overrides" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Middle Actions -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="_button_save_load_scheme" Style="{StaticResource BtnBase}" Click="save_load_color_scheme" Margin="0,0,12,0" Width="180" ToolTip="Save current color scheme or load a saved scheme from file">
                    <Grid Width="150">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Save / Load Scheme" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
                <Button Style="{StaticResource BtnBase}" Width="130" Click="button_click_export_csv" ToolTip="Export values, counts, and colors report to CSV or JSON">
                    <Grid Width="100">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Export" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
                <Button x:Name="_button_export_csv" Visibility="Collapsed"/>
                <Button x:Name="_button_export_json" Visibility="Collapsed"/>
                <Button x:Name="_button_select_all" Visibility="Collapsed"/>
                <Button x:Name="_button_select_none" Visibility="Collapsed"/>
            </StackPanel>

            <!-- Apply -->
            <Button x:Name="_button_set_colors" Grid.Column="2" Style="{StaticResource BtnPrimary}" Click="button_click_set_colors" Width="320" Height="48" ToolTip="Apply colors to all elements of selected category in active Revit view">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="18"/>
                    <TextBlock Text="Apply Colors" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ════════════════════════ STATUS BAR ════════════════════════ -->
        <Grid Grid.Row="5" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="_status_dot" Width="8" Height="8" Fill="#22C55E" Margin="0,1,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="_txt_status" Text="Ready" Foreground="#22C55E" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock x:Name="_txt_footer_status" Visibility="Collapsed"/>

            <TextBlock Grid.Column="2" Text="Hold SHIFT + Click elements to select" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
            <Border Grid.Column="4" Width="14" Height="14" CornerRadius="7" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" Background="White" VerticalAlignment="Center">
                <TextBlock Text="i" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
            </Border>

            <!-- Hidden warning block compatibility -->
            <TextBlock x:Name="_txt_block5" Visibility="Collapsed"/>
            <TextBlock x:Name="_txt_revit_ver" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
